3000 4000 3000 4000 1 3 3003 33 3 3100 11 9 3000
3000 4000 3000 4000 1 3 3003 11 3 3001 11 9 3000
3000 4000 3000 4000 1 3 3200 33 3 3100 11 9 3000
3000 4000 3000 4000 1 3 3200 11 3 3001 11 9 3000

# Query 2 - (id > id2) then (id > id4), tumbling 1 sec
# Tests: reversed direction: stream.id must exceed both joined stream ids — tests that the engine correctly handles the > operator and does not conflate it with <
SELECT * FROM (SELECT * FROM stream)
 INNER JOIN (SELECT * FROM stream2) ON id > id2 WINDOW TUMBLING (timestamp, size 1 sec)
 INNER JOIN (SELECT * FROM stream4) ON id > id4 WINDOW TUMBLING (timestamp, size 1 sec)
 INTO sinkGt;
----
1000 2000 1000 2000 12 1 1001 4 3 1102 4 4 1001
1000 2000 1000 2000 12 1 1001 4 3 1112 4 4 1001

# Query 3 - (id <= id2) then (id <= id4), tumbling 1 sec
# Tests: <= includes equal-value id pairs that < would exclude — verifies the boundary case at equality
SELECT * FROM (SELECT * FROM stream)
 INNER JOIN (SELECT * FROM stream2) ON id <= id2 WINDOW TUMBLING (timestamp, size 1 sec)
 INNER JOIN (SELECT * FROM stream4) ON id <= id4 WINDOW TUMBLING (timestamp, size 1 sec)
 INTO sinkLe;
