# Query 6 - (id < id2) then (id < id4), tumbling 2 sec
# Tests: three-stream chained join with a 2-second window — triples whose records span adjacent 1-second buckets become eligible, expanding the result set compared to Q1
SELECT * FROM (SELECT * FROM stream)
 INNER JOIN (SELECT * FROM stream2) ON id < id2 WINDOW TUMBLING (timestamp, size 2 sec)
 INNER JOIN (SELECT * FROM stream4) ON id < id4 WINDOW TUMBLING (timestamp, size 2 sec)
 INTO sinkLtTumbling2s;
