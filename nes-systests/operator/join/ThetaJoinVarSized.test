3000 3500 11 3 3001 33 3 3100
3000 3500 1 3 3003 33 3 3100
3000 3500 1 3 3003 11 3 3001
3000 3500 1 3 3200 33 3 3100
3000 3500 1 3 3200 11 3 3001

# Query 6 - id < id2, sliding 2 sec advance 1 sec
# Tests: doubling the sliding window size compared to Q3/Q4 — a 2-second window can pair records up to 2 seconds apart while still overlapping, producing more pairs than any 1-second sliding window
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 WINDOW SLIDING (timestamp, size 2 sec, advance by 1 sec) INTO sinkSliding2s1s;
