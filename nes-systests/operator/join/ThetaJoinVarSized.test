# name: theta_join/ThetaJoinVarSized.test
# description: Same predicate across different window sizes and types to isolate window parameter effects
# groups: [WindowOperators, Join, CompilationIntensive]

# Source definitions
CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH FILE small/stream.csv

CREATE LOGICAL SOURCE stream2(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH FILE small/stream2.csv

CREATE LOGICAL SOURCE stream7(id7 UINT64 NOT NULL, value7 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream7 TYPE File;
ATTACH FILE small/stream7.csv

CREATE LOGICAL SOURCE stream7_1(id7_1 UINT64 NOT NULL, value7_1 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream7_1 TYPE File;
ATTACH FILE small/stream7.csv

CREATE SINK sinkTumbling1s(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;
CREATE SINK sinkTumbling2s(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;
CREATE SINK sinkSliding500ms(stream7stream7_1.start UINT64 NOT NULL, stream7stream7_1.end UINT64 NOT NULL, stream7.id7 UINT64 NOT NULL, stream7.value7 UINT64 NOT NULL, stream7.timestamp UINT64 NOT NULL, stream7_1.id7_1 UINT64 NOT NULL, stream7_1.value7_1 UINT64 NOT NULL, stream7_1.timestamp UINT64 NOT NULL) TYPE File;
CREATE SINK sinkSliding250ms(stream7stream7_1.start UINT64 NOT NULL, stream7stream7_1.end UINT64 NOT NULL, stream7.id7 UINT64 NOT NULL, stream7.value7 UINT64 NOT NULL, stream7.timestamp UINT64 NOT NULL, stream7_1.id7_1 UINT64 NOT NULL, stream7_1.value7_1 UINT64 NOT NULL, stream7_1.timestamp UINT64 NOT NULL) TYPE File;
CREATE SINK sinkTumbling500ms(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;
CREATE SINK sinkSliding2s1s(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;

# Query 1 - id < id2, tumbling 1 sec
# Tests: baseline — records whose timestamps fall in the same 1-second bucket are eligible to join
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkTumbling1s;
----
1000 2000 1 1 1000 21 1 1003
1000 2000 1 1 1000 12 5 1011
1000 2000 1 1 1000 4 3 1102
1000 2000 1 1 1000 4 3 1112
1000 2000 12 1 1001 21 1 1003
1000 2000 4 1 1002 21 1 1003
1000 2000 4 1 1002 12 5 1011
2000 3000 1 2 2000 11 2 2301
3000 4000 1 3 3000 33 3 3100
3000 4000 1 3 3000 11 3 3001
3000 4000 11 3 3001 33 3 3100
3000 4000 1 3 3003 33 3 3100
3000 4000 1 3 3003 11 3 3001
3000 4000 1 3 3200 33 3 3100
3000 4000 1 3 3200 11 3 3001

# Query 2 - id < id2, tumbling 2 sec
# Tests: doubling the window size groups records from two consecutive 1-second buckets together, producing more join pairs than Q1
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 WINDOW TUMBLING (timestamp, size 2 sec) INTO sinkTumbling2s;
----
0 2000 1 1 1000 21 1 1003
0 2000 1 1 1000 12 5 1011
0 2000 1 1 1000 4 3 1102
