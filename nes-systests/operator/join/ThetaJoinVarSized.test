# Query 5 - id < id2, tumbling 500 ms
# Tests: halving the window size compared to Q1 — only records within the same 500-millisecond bucket can join, producing fewer pairs and demonstrating the effect of a smaller tumbling window
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 WINDOW TUMBLING (timestamp, size 500 ms) INTO sinkTumbling500ms;
----
1000 1500 1 1 1000 21 1 1003
1000 1500 1 1 1000 12 5 1011
1000 1500 1 1 1000 4 3 1102
1000 1500 1 1 1000 4 3 1112
1000 1500 12 1 1001 21 1 1003
1000 1500 4 1 1002 21 1 1003
1000 1500 4 1 1002 12 5 1011
