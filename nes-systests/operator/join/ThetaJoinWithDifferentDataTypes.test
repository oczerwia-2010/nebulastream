# name: theta_join/ThetaJoinWithDifferentDataTypes.test
# description: Theta join on UINT64 integer fields with tumbling and sliding windows
# groups: [WindowOperators, Join, CompilationIntensive]

CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH FILE small/stream.csv

CREATE LOGICAL SOURCE stream2(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH FILE small/stream2.csv

CREATE SINK sinkUint64Lt(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;
CREATE SINK sinkUint64LtSliding(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;

# Query 1 - UINT64 id < id2, tumbling 1 sec
# Tests: less-than on unsigned 64-bit integer join keys
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkUint64Lt;
----
1000 2000 1 1 1000 21 1 1003
1000 2000 1 1 1000 12 5 1011
1000 2000 1 1 1000 4 3 1102
1000 2000 1 1 1000 4 3 1112
1000 2000 12 1 1001 21 1 1003
1000 2000 4 1 1002 21 1 1003
1000 2000 4 1 1002 12 5 1011
2000 3000 1 2 2000 11 2 2301
3000 4000 1 3 3000 33 3 3100
3000 4000 1 3 3000 11 3 3001
3000 4000 11 3 3001 33 3 3100
3000 4000 1 3 3003 33 3 3100
3000 4000 1 3 3003 11 3 3001
3000 4000 1 3 3200 33 3 3100
3000 4000 1 3 3200 11 3 3001

# Query 2 - UINT64 id < id2, sliding 1 sec advance 500 ms
# Tests: UINT64 less-than with a sliding window — verifies integer comparison is not specific to tumbling
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 WINDOW SLIDING (timestamp, size 1 sec, advance by 500 ms) INTO sinkUint64LtSliding;
----
500 1500 1 1 1000 21 1 1003
500 1500 1 1 1000 12 5 1011
500 1500 1 1 1000 4 3 1102
500 1500 1 1 1000 4 3 1112
500 1500 12 1 1001 21 1 1003
500 1500 4 1 1002 21 1 1003
500 1500 4 1 1002 12 5 1011
1000 2000 1 1 1000 21 1 1003
1000 2000 1 1 1000 12 5 1011
1000 2000 1 1 1000 4 3 1102
1000 2000 1 1 1000 4 3 1112
1000 2000 12 1 1001 21 1 1003
1000 2000 4 1 1002 21 1 1003
1000 2000 4 1 1002 12 5 1011
1500 2500 1 2 2000 11 2 2301
2000 3000 1 2 2000 11 2 2301
2500 3500 1 3 3000 33 3 3100
2500 3500 1 3 3000 11 3 3001
2500 3500 11 3 3001 33 3 3100
