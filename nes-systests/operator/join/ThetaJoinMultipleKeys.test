# name: theta_join/ThetaJoinJoinMultipleKeys.test
# description: Join with compound AND predicates on two fields, tumbling and sliding windows
# groups: [WindowOperators, Join, CompilationIntensive]

# Source definitions
CREATE LOGICAL SOURCE stream(id UINT64 NOT NULL, value UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH FILE small/stream.csv

CREATE LOGICAL SOURCE stream2(id2 UINT64 NOT NULL, value2 UINT64 NOT NULL, timestamp UINT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH FILE small/stream2.csv

CREATE SINK sinkStreamStream2(streamstream2.start UINT64 NOT NULL, streamstream2.end UINT64 NOT NULL, stream.id UINT64 NOT NULL, stream.value UINT64 NOT NULL, stream.timestamp UINT64 NOT NULL, stream2.id2 UINT64 NOT NULL, stream2.value2 UINT64 NOT NULL, stream2.timestamp UINT64 NOT NULL) TYPE File;

# Query 1 - id < id2 AND value < value2, tumbling 1 sec
# Tests: both AND conditions must hold simultaneously — a pair satisfying only one condition is not emitted
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 AND value < value2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkStreamStream2;
----
1000 2000 1 1 1000 12 5 1011
1000 2000 1 1 1000 4 3 1102
1000 2000 1 1 1000 4 3 1112
1000 2000 4 1 1002 12 5 1011

# Query 2 - id <= id2 AND value >= value2, tumbling 1 sec
# Tests: opposing comparison directions in a compound predicate — id must not exceed id2 while value must not be smaller than value2
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id <= id2 AND value >= value2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkStreamStream2;
