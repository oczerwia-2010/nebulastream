# Query 4 - id < id2 AND value < value2, sliding 1 sec advance 500 ms
# Tests: compound AND predicate with a sliding window — the same matching pair appears once per overlapping window it falls into
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 AND value < value2 WINDOW SLIDING (timestamp, size 1 sec, advance by 500 ms) INTO sinkStreamStream2;
----
500 1500 1 1 1000 12 5 1011
500 1500 1 1 1000 4 3 1102
500 1500 1 1 1000 4 3 1112
500 1500 4 1 1002 12 5 1011
1000 2000 1 1 1000 12 5 1011
1000 2000 1 1 1000 4 3 1102
1000 2000 1 1 1000 4 3 1112
1000 2000 4 1 1002 12 5 1011

# Query 5 - id < id2 AND value < value2, tumbling 2 sec
# Tests: a wider 2-second window groups records from two adjacent 1-second buckets together — pairs that fall in different 1-second windows (excluded in Q1) can join here
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 AND value < value2 WINDOW TUMBLING (timestamp, size 2 sec) INTO sinkStreamStream2;
----
0 2000 1 1 1000 12 5 1011
0 2000 1 1 1000 4 3 1102
0 2000 1 1 1000 4 3 1112
0 2000 4 1 1002 12 5 1011
2000 4000 1 2 2000 33 3 3100
2000 4000 1 2 2000 11 3 3001
2000 4000 11 2 2001 33 3 3100
2000 4000 16 2 2002 33 3 3100

# Query 6 - id < id2 AND value < value2, sliding 500 ms advance 250 ms
# Tests: sub-second sliding window with a compound predicate — the smaller window size than Q4 limits which records co-occur, combining stricter temporal proximity with the AND requirement
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 AND value < value2 WINDOW SLIDING (timestamp, size 500 ms, advance by 250 ms) INTO sinkStreamStream2;
----
750 1250 1 1 1000 12 5 1011
750 1250 1 1 1000 4 3 1102
750 1250 1 1 1000 4 3 1112
750 1250 4 1 1002 12 5 1011
1000 1500 1 1 1000 12 5 1011
1000 1500 1 1 1000 4 3 1102
1000 1500 1 1 1000 4 3 1112
1000 1500 4 1 1002 12 5 1011

# Query 7 - id > id2 AND value > value2, tumbling 1 sec
# Tests: reversed compound predicate — both fields in stream must exceed their counterparts in stream2, the mirror image of Q1
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id > id2 AND value > value2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkStreamStream2;
----

# Query 8 - id >= id2 AND value >= value2, tumbling 1 sec
# Tests: non-strict reversed compound — >= includes equal-value pairs that > excludes, producing a superset of Q7's output
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id >= id2 AND value >= value2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkStreamStream2;
