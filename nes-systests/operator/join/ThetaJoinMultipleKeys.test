# Query 9 - id > id2 AND value < value2, tumbling 1 sec
# Tests: opposing strict compound — id must exceed id2 while value must be smaller, a combination that cannot be satisfied by equal-field pairs
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id > id2 AND value < value2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkStreamStream2;
----
1000 2000 12 1 1001 4 3 1102
1000 2000 12 1 1001 4 3 1112

# Query 10 - id < id2 AND value >= value2, tumbling 1 sec
# Tests: mixed strict/non-strict opposing — strict < on id with non-strict >= on value, admitting pairs where values are equal but id is strictly smaller
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id < id2 AND value >= value2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkStreamStream2;
----
1000 2000 1 1 1000 21 1 1003
1000 2000 12 1 1001 21 1 1003
1000 2000 4 1 1002 21 1 1003
2000 3000 1 2 2000 11 2 2301
3000 4000 1 3 3000 33 3 3100
3000 4000 1 3 3000 11 3 3001
3000 4000 11 3 3001 33 3 3100
3000 4000 1 3 3003 33 3 3100
3000 4000 1 3 3003 11 3 3001
3000 4000 1 3 3200 33 3 3100
3000 4000 1 3 3200 11 3 3001

# Query 11 - id >= id2 AND value < value2, tumbling 1 sec
# Tests: non-strict/strict opposing — id may equal id2 but value must be strictly smaller, admitting pairs excluded by both Q2 and Q9
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id >= id2 AND value < value2 WINDOW TUMBLING (timestamp, size 1 sec) INTO sinkStreamStream2;
----
1000 2000 12 1 1001 12 5 1011
1000 2000 12 1 1001 4 3 1102
1000 2000 12 1 1001 4 3 1112
1000 2000 4 1 1002 4 3 1102
1000 2000 4 1 1002 4 3 1112

# Query 12 - id > id2 AND value > value2, sliding 1 sec advance 500 ms
# Tests: reversed compound predicate with a sliding window — same sliding behaviour as Q4 but for the > direction, each qualifying pair appears once per overlapping window
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id > id2 AND value > value2 WINDOW SLIDING (timestamp, size 1 sec, advance by 500 ms) INTO sinkStreamStream2;
----

# Query 13 - id >= id2 AND value <= value2, sliding 500 ms advance 250 ms
# Tests: symmetric non-strict opposing compound (id >= while value <=) with a sub-second sliding window — verifies both >= and <= directions work correctly at high window density
SELECT * FROM (SELECT * FROM stream) INNER JOIN (SELECT * FROM stream2) ON id >= id2 AND value <= value2 WINDOW SLIDING (timestamp, size 500 ms, advance by 250 ms) INTO sinkStreamStream2;
